<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Tobacco.Views"
        x:Class="Tobacco.MainWindow"
        Title="Tobacco"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f1a">

    <Grid ColumnDefinitions="200,*">

        <Border Grid.Column="0" Background="#12122a" BorderBrush="#1e1e38" BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,32">
                    <TextBlock Text="TOBACCO" FontSize="22" FontWeight="Bold" Foreground="#e67e22"
                               HorizontalAlignment="Left" />
                    <TextBlock Text="codec &amp; synthesizer" FontSize="11" Foreground="#606088"
                               HorizontalAlignment="Left" Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,20">
                    <Border Background="#1a1a32" CornerRadius="8" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="version 1.0" FontSize="10" Foreground="#505070" />
                            <TextBlock Text="WHT block codec" FontSize="10" Foreground="#505070" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="2" Margin="12,0">
                    <Button x:Name="NavPlayer" Classes="accent" Content="  Player"
                            HorizontalContentAlignment="Left" Height="38" Click="OnNavPlayer"
                            Margin="0,0,0,0" />
                    <Button x:Name="NavConverter" Content="  Converter"
                            HorizontalContentAlignment="Left" Height="38" Click="OnNavConverter"
                            Margin="0,2,0,0" />
                    <Button x:Name="NavSynth" Content="  Synth"
                            HorizontalContentAlignment="Left" Height="38" Click="OnNavSynth"
                            Margin="0,2,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Panel Grid.Column="1" Margin="0">
            <views:PlayerView x:Name="PlayerView" />
            <views:ConverterView x:Name="ConverterView" IsVisible="False" />
            <views:SynthView x:Name="SynthView" IsVisible="False" />
        </Panel>

    </Grid>
</Window>
