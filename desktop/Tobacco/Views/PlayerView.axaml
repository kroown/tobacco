<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Tobacco.Views.PlayerView">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="8">

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Open .blunt" Click="OnOpenFile" Width="120" />
            <TextBlock x:Name="FileNameText" Text="No file loaded" VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1" Background="#1a1a2e" CornerRadius="4" ClipToBounds="True">
            <Canvas x:Name="VideoCanvas" Background="#1a1a2e">
                <Image x:Name="VideoImage" Stretch="Uniform" />
            </Canvas>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Play" Click="OnPlay" Width="80" />
            <Button Content="Pause" Click="OnPause" Width="80" />
            <Button Content="Stop" Click="OnStop" Width="80" />
            <Slider x:Name="PositionSlider" Minimum="0" Maximum="100" Width="400"
                    ValueChanged="OnPositionChanged" />
            <TextBlock x:Name="PositionText" Text="0:00 / 0:00" VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="3" x:Name="StatusText" Text="Ready" Margin="0,8,0,0" />
    </Grid>
</UserControl>
