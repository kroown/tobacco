<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Tobacco.Views.PlayerView">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="28,24,28,20" ColumnDefinitions="*">

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <Button Classes="accent" Content="Open File" Click="OnOpenFile" Padding="16,10" />
            <TextBlock x:Name="FileNameText" Text="No file loaded" VerticalAlignment="Center"
                       FontSize="14" Foreground="#a0a0b8" />
        </StackPanel>

        <Border Grid.Row="1" Background="#0a0a18" CornerRadius="12" ClipToBounds="True"
                BorderBrush="#1e1e38" BorderThickness="1">
            <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas x:Name="VideoCanvas" Background="Transparent">
                    <Image x:Name="VideoImage" Stretch="Uniform" />
                </Canvas>
                <StackPanel x:Name="Placeholder" VerticalAlignment="Center" HorizontalAlignment="Center"
                            IsVisible="True">
                    <TextBlock Text="&#x25B6;" FontSize="48" Foreground="#2a2a48"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Open a .blunt file to play" FontSize="13" Foreground="#404060"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Panel>
        </Border>

        <Border Grid.Row="2" Background="#12122a" CornerRadius="10" Padding="16,10" Margin="0,10,0,0">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <Button x:Name="PlayBtn" Classes="accent" Content="&#x25B6;" Click="OnPlay"
                            Width="42" Height="36" FontSize="16" />
                    <Button x:Name="PauseBtn" Content="&#x2016;" Click="OnPause"
                            Width="42" Height="36" FontSize="16" />
                    <Button x:Name="StopBtn" Content="&#x25A0;" Click="OnStop"
                            Width="42" Height="36" FontSize="14" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:Name="FrameText" Text="0:00" FontSize="12" Foreground="#8080a0"
                               MinWidth="40" FontFamily="Consolas, monospace" />
                </StackPanel>

                <Slider Grid.Column="3" x:Name="PositionSlider" Minimum="0" Maximum="100"
                        VerticalAlignment="Center" ValueChanged="OnPositionChanged" />

                <TextBlock Grid.Column="4" x:Name="DurationText" Text="0:00" FontSize="12"
                           Foreground="#606080" VerticalAlignment="Center"
                           FontFamily="Consolas, monospace" />
            </Grid>
        </Border>

        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,6,0,0">
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="11" Foreground="#505070" />
            <TextBlock Grid.Column="1" x:Name="InfoText" Text="" FontSize="11" Foreground="#505070" />
        </Grid>

    </Grid>
</UserControl>
