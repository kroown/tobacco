<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Tobacco.Views.ConverterView">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24" Spacing="0">

            <TextBlock Classes="heading" Text="Converter" Margin="0,0,0,4" />
            <TextBlock Classes="muted" Text="Convert between WAV, MP4, and .blunt formats" Margin="0,0,0,20" />

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Classes="label" Text="DIRECTION" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="BtnWavToBlunt" Classes="accent" Content="WAV  &#x2192;  .blunt"
                                Width="150" Height="40" Click="OnSelectMode" Tag="0" />
                        <Button x:Name="BtnBluntToWav" Content=".blunt  &#x2192;  WAV"
                                Width="150" Height="40" Click="OnSelectMode" Tag="1" />
                        <Button x:Name="BtnMp4ToBlunt" Content="MP4  &#x2192;  .blunt"
                                Width="150" Height="40" Click="OnSelectMode" Tag="2" />
                        <Button x:Name="BtnBluntToMp4" Content=".blunt  &#x2192;  MP4"
                                Width="150" Height="40" Click="OnSelectMode" Tag="3" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Classes="label" Text="INPUT FILE" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Classes="accent" Content="Browse..." Click="OnOpenFile" Padding="20,10" />
                        <Border Background="#1a1a30" CornerRadius="6" Padding="12,8" MinWidth="300">
                            <TextBlock x:Name="InputFileText" Text="No file selected"
                                       Foreground="#606080" VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Classes="label" Text="QUALITY" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                        <Slider Grid.Column="0" x:Name="QualitySlider" Minimum="1" Maximum="100" Value="80"
                                VerticalAlignment="Center" ValueChanged="OnQualityChanged" />
                        <Border Grid.Column="1" Background="#1a1a30" CornerRadius="6" Padding="14,6"
                                MinWidth="50" HorizontalAlignment="Right">
                            <TextBlock x:Name="QualityText" Text="80" HorizontalAlignment="Center"
                                       FontFamily="Consolas, monospace" FontWeight="SemiBold" Foreground="#e67e22" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Button Classes="accent" Content="Convert" Click="OnConvert"
                    Height="42" HorizontalAlignment="Left" Padding="32,0" Margin="0,4,0,12" />

            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock Classes="label" Text="LOG" />
                    <Border Background="#0a0a18" CornerRadius="8" Padding="2" MinHeight="180">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="LogBox" Text="" FontFamily="Consolas, monospace"
                                       FontSize="12" Foreground="#8888a8" TextWrapping="Wrap"
                                       Margin="10,8" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusText" Text="Ready" FontSize="11" Foreground="#505070"
                       Margin="0,4,0,0" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
